  "keyFeatures": [
    "Role-based authentication (Admin and Branch users)",
    "Dynamic order weight calculator with 11,500 kg limit (13,000 kg database maximum)",
    "Draft and workflow state management (draft → sent → approved → printed)",
    "168-material catalog across 5 categories (raw materials, essences, containers, colors, miscellaneous)",
    "PDF generation with specialized sorting format",
    "Real-time weight tracking in kilos and tons",
    "Row-level security with Supabase RLS",
    "Multi-branch order management dashboard"
  ],
  "publicApiSurface": [
    "Authentication via Supabase Auth (email/password)",
    "Orders API (pedidos table)",
    "Materials Catalog API (materiales table)",
    "Branch Management API (sucursales table)",
    "Order Details API (pedido_detalle table)",
    "User Management API (users table)",
    "Access Requests API (solicitudes_acceso table)",
    "validate_pedido_limit() RPC function"
  ]
